@inherits ElsaMina.Core.Services.Templates.LocalizableTemplatePage<ElsaMina.Core.Services.Templates.LocalizableViewModel>

<div style="color:#4488cc;font-size:9pt;text-align:center;margin-bottom:4px">
    <b>@GetString("top_tournament_players_footer_new_label")</b> @GetString("top_tournament_players_footer_new_text")
</div>
<details style="width: 100%">
    <summary>@GetString("top_tournament_players_footer_rewards_title")</summary>
    <p>@GetString("top_tournament_players_footer_description_prefix") <code>-board</code> @GetString("top_tournament_players_footer_description_infix") <b><span class="username" style="color: #1ea767">Elsa-Mina</span></b>@GetString("top_tournament_players_footer_description_suffix")</p>
    <ul>
        <li><b>20 @GetString("top_tournament_players_wins")</b>: @GetString("top_tournament_players_footer_20_wins") <span class="username" style="color: #1ea767">Elsa-Mina</span></li>
        <li><b>30 @GetString("top_tournament_players_wins")</b>: @GetString("top_tournament_players_footer_30_wins") <span class="username" style="color: #1ea767">Elsa-Mina</span></li>
        <li><b>40 @GetString("top_tournament_players_wins")</b>: @GetString("top_tournament_players_footer_40_wins") <span class="username" style="color: #1ea767">Elsa-Mina</span></li>
        <li><b>50 @GetString("top_tournament_players_wins")</b>: @GetString("top_tournament_players_footer_50_wins")</li>
        <li><b>100 @GetString("top_tournament_players_wins")</b>: @GetString("top_tournament_players_footer_100_wins")</li>
        <li><b>150 @GetString("top_tournament_players_wins")</b>: @GetString("top_tournament_players_footer_150_wins")</li>
    </ul>
</details>
