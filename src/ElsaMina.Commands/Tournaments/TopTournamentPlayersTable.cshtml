@using ElsaMina.Core.Services.Templates
@using ElsaMina.Core.Utils
@inherits ElsaMina.Core.Services.Templates.LocalizableTemplatePage<ElsaMina.Commands.Tournaments.TopTournamentPlayersViewModel>

@{
    const string headerStyle = $"border-bottom: 1px solid {StyleConstants.PRIMARY_BORDER_COLOR}; padding: 4px";
}
<div style="max-height: 200px; overflow-y: auto">
    <table
        style="margin: auto; border: 1px solid @StyleConstants.PRIMARY_BORDER_COLOR; border-radius: 12px; padding: 4px">
        <thead>
        <tr>
            <th colspan="7" scope="colgroup">
                @GetString("top_tournament_players_title", Model.Room)
            </th>
        </tr>
        <tr>
            <th scope="col" style="@headerStyle">#</th>
            <th scope="col" style="@headerStyle">@GetString("top_tournament_players_user")</th>
            <th scope="col" style="@headerStyle">@GetString("top_tournament_players_wins")</th>
            <th scope="col" style="@headerStyle">@GetString("top_tournament_players_runner_up")</th>
            <th scope="col" style="@headerStyle">@GetString("top_tournament_players_third_place")</th>
            <th scope="col" style="@headerStyle">@GetString("top_tournament_players_win_rate")</th>
            <th scope="col" style="@headerStyle">@GetString("top_tournament_players_entered")</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var entry in Model.TopList)
        {
            var winRate = entry.PlayedGames > 0
                ? $"{(double)entry.WonGames / entry.PlayedGames:P0}"
                : "—";
            <tr>
                <td style="text-align:center">@entry.Rank</td>
                <td style="text-align:center;">
                    <span
                        class="username"
                        data-name="@entry.UserId"
                        style="color: @entry.UserId.ToColorHexCodeWithCustoms()">
                        @entry.UserName
                    </span>
                </td>
                <td style="text-align:center">@entry.WinsCount</td>
                <td style="text-align:center">@entry.RunnerUpCount</td>
                <td style="text-align:center">@entry.ThirdPlaceCount</td>
                <td style="text-align:center">@winRate</td>
                <td style="text-align:center">@entry.TournamentsEnteredCount</td>
            </tr>
        }
        </tbody>
    </table>
</div>
