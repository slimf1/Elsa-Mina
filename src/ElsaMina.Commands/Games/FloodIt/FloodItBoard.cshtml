@using ElsaMina.Commands.Games.FloodIt
@using ElsaMina.Core.Services.Templates
@inherits ElsaMina.Core.Services.Templates.LocalizableTemplatePage<ElsaMina.Commands.Games.FloodIt.FloodItModel>

@{
    var game = Model.CurrentGame;
    var size = game.GridSize;
    var colors = FloodItConstants.COLOR_HEX;

    const string borderColor = StyleConstants.PRIMARY_BORDER_COLOR;
    const string bgColor = StyleConstants.PRIMARY_BACKGROUND_COLOR;
    const string cellStyle = $"border: 1px solid {borderColor};";
    const string cellStyleWithBg = $"border: 1px solid {borderColor}; background-color: {bgColor};";

    var cellSize = size <= 8 ? 34 : size <= 10 ? 28 : size <= 12 ? 24 : 20;
}

<table style="border-collapse: collapse; width: 100%;">
    <thead>
        <tr>
            <th style="@cellStyleWithBg">@GetString("fi_panel_title")</th>
            <th style="@cellStyleWithBg">@GetString("fi_panel_level", game.Level) (@(size)x@(size)) — @GetString("fi_panel_moves", game.MoveCount, game.MaxMoves)</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td style="@cellStyle text-align: center; vertical-align: top;">
                <div style="display: inline-block; padding: 6px; background: #1a1a2e; border-radius: 6px;">
                    <table style="border-collapse: separate; border-spacing: 2px; margin: auto;">
                        @for (var row = 0; row < size; row++)
                        {
                            <tr>
                                @for (var col = 0; col < size; col++)
                                {
                                    var colorIdx = game.Grid[row, col];
                                    var colorHex = colors[colorIdx];
                                    var claimed = game.IsClaimed[row, col];
                                    var cellBorder = claimed ? "2px solid rgba(255,255,255,0.6)" : "2px solid rgba(0,0,0,0.3)";
                                    var isCurrentColor = colorIdx == game.Grid[0, 0];
                                    <td style="padding: 0;">
                                        @if (game.IsRoundActive && !isCurrentColor)
                                        {
                                            <button
                                                name="send"
                                                value="/botmsg @Model.BotName,@(Model.Trigger)ficolor @Model.RoomId, @colorIdx"
                                                style="width: @(cellSize)px; height: @(cellSize)px; background-color: @colorHex; border: @cellBorder; border-radius: 3px; cursor: pointer; box-sizing: border-box; padding: 0;">
                                            </button>
                                        }
                                        else
                                        {
                                            <div style="width: @(cellSize)px; height: @(cellSize)px; background-color: @colorHex; border: @cellBorder; border-radius: 3px; box-sizing: border-box;"></div>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </table>
                </div>
            </td>
            <td style="padding: 16px; @cellStyle vertical-align: top; min-width: 160px;">
                <span style="font-weight: bold; font-size: 1.1em;">@GetString("fi_panel_title")</span><br/>
                @if (game.Owner != null)
                {
                    <span style="color: #666; font-size: 0.9em;">@GetString("fi_panel_player", game.Owner.Name)</span><br/>
                    <span style="color: #666; font-size: 0.9em;">@GetString("fi_panel_total_stars", game.TotalStars)</span><br/>
                }
                @if (game.Stars > 0)
                {
                    <span style="font-size: 1.2em;">@(new string('★', game.Stars))@(new string('☆', 3 - game.Stars))</span><br/>
                }
                <br/>
                <span>@GetString("fi_panel_objective")</span><br/>
                <span>@GetString("fi_panel_hint")</span><br/>
                <span>@GetString("fi_panel_timeout_hint")</span><br/>
                <br/>
                @if (!game.IsEnded)
                {
                    <details>
                        <summary>@GetString("fi_panel_options")</summary>
                        <br/>
                        @if (!game.IsRoundActive)
                        {
                            <button
                                class="button"
                                name="send"
                                value="@(Model.IsPrivateMode ? $"/botmsg {Model.BotName},{Model.Trigger}floodit {Model.RoomId}" : $"{Model.Trigger}floodit")">
                                @GetString("fi_panel_new_round")
                            </button>
                            <br/><br/>
                        }
                        <button
                            class="button"
                            name="send"
                            value="@(Model.IsPrivateMode ? $"/botmsg {Model.BotName},{Model.Trigger}fiend {Model.RoomId}" : $"{Model.Trigger}fiend")">
                            @GetString("fi_panel_stop")
                        </button>
                    </details>
                }
                else
                {
                    <br/>
                    <button
                        class="button"
                        name="send"
                        value="@(Model.IsPrivateMode ? $"/botmsg {Model.BotName},{Model.Trigger}floodit {Model.RoomId}" : $"{Model.Trigger}floodit")">
                        @GetString("fi_panel_play_again")
                    </button>
                }
            </td>
        </tr>
    </tbody>
</table>
