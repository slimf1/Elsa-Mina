@inherits ElsaMina.Core.Services.Templates.LocalizableTemplatePage<ElsaMina.Commands.TwentyFortyEight.TwentyFortyEightModel>

<div>
    <h3>@GetString("tfe_panel_title")</h3>
    <span>@GetString("tfe_panel_waiting_for_player")</span><br/><br/>
    <button
        class="button"
        name="send"
        value="/botmsg @Model.BotName,@(Model.Trigger)2048join @Model.RoomId">
        @GetString("tfe_panel_join")
    </button>
</div>
