@using ElsaMina.Commands.LightsOut
@using ElsaMina.Core.Services.Templates
@inherits ElsaMina.Core.Services.Templates.LocalizableTemplatePage<ElsaMina.Commands.LightsOut.LightsOutModel>

@{
    var game = Model.CurrentGame;
    var size = game.GridSize;

    const string borderColor = StyleConstants.PRIMARY_BORDER_COLOR;
    const string bgColor = StyleConstants.PRIMARY_BACKGROUND_COLOR;
    const string cellStyle = $"border: 1px solid {borderColor};";
    const string cellStyleWithBg = $"border: 1px solid {borderColor}; background-color: {bgColor};";

    const string litStyle = "background: linear-gradient(135deg, #FFE44D, #FFB800); border: 2px solid #E6A800; box-shadow: 0 0 8px #FFD70088;";
    const string unlitStyle = "background: linear-gradient(135deg, #3a3a4a, #1e1e2e); border: 2px solid #111;";
    const string gridBg = "background-color: #1a1a2e; padding: 8px; border-radius: 8px;";

    var cellSize = size <= 5 ? 48 : size <= 6 ? 40 : 34;
}

<table style="border-collapse: collapse; width: 100%;">
    <thead>
        <tr>
            <th style="@cellStyleWithBg">@GetString("lo_panel_title")</th>
            <th style="@cellStyleWithBg">@GetString("lo_panel_level", game.Level) (@(size)x@(size)) — @GetString("lo_panel_moves", game.MoveCount)</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td style="@cellStyle text-align: center;">
                <div style="@gridBg display: inline-block;">
                    <table style="border-collapse: separate; border-spacing: 4px; margin: auto;">
                        @for (var row = 0; row < size; row++)
                        {
                            <tr>
                                @for (var col = 0; col < size; col++)
                                {
                                    var isLit = game.Grid[row, col];
                                    <td>
                                        @if (game.IsRoundActive)
                                        {
                                            <button
                                                class="button"
                                                name="send"
                                                value="/botmsg @Model.BotName,@(Model.Trigger)lotoggle @Model.RoomId, @row, @col"
                                                style="width: @(cellSize)px; height: @(cellSize)px; cursor: pointer; border-radius: 6px; @(isLit ? litStyle : unlitStyle)">
                                            </button>
                                        }
                                        else
                                        {
                                            <div style="width: @(cellSize)px; height: @(cellSize)px; border-radius: 6px; @(isLit ? litStyle : unlitStyle)"></div>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </table>
                </div>
            </td>
            <td style="padding: 20px; @cellStyle vertical-align: top;">
                <span style="font-weight: bold; font-size: 1.1em;">@GetString("lo_panel_title")</span><br/>
                @if (game.Owner != null)
                {
                    <span style="color: #666; font-size: 0.9em;">@GetString("lo_panel_player", game.Owner.Name)</span><br/>
                    <span style="color: #666; font-size: 0.9em;">@GetString("lo_panel_total_stars", game.TotalStars)</span><br/>
                }
                @if (game.Stars > 0)
                {
                    <span style="font-size: 1.2em;">@(new string('★', game.Stars))@(new string('☆', 3 - game.Stars))</span><br/>
                }
                <br/>
                <span>@GetString("lo_panel_objective")</span><br/>
                <span>@GetString("lo_panel_hint")</span><br/>
                <span>@GetString("lo_panel_timeout_hint")</span><br/>
                <br/>
                <div style="display: inline-block; width: 18px; height: 18px; background: linear-gradient(135deg, #FFE44D, #FFB800); border: 1px solid #E6A800; border-radius: 3px; vertical-align: middle;"></div>&nbsp;@GetString("lo_panel_legend_lit")<br/>
                <div style="display: inline-block; width: 18px; height: 18px; background: linear-gradient(135deg, #3a3a4a, #1e1e2e); border: 1px solid #111; border-radius: 3px; vertical-align: middle;"></div>&nbsp;@GetString("lo_panel_legend_unlit")<br/>
                <br/>
                @if (!game.IsEnded)
                {
                    <details>
                        <summary>@GetString("lo_panel_options")</summary>
                        <br/>
                        @if (!game.IsRoundActive)
                        {
                            <button
                                class="button"
                                name="send"
                                value="@(Model.IsPrivateMode ? $"/botmsg {Model.BotName},{Model.Trigger}lightsout {Model.RoomId}" : $"{Model.Trigger}lightsout")">
                                @GetString("lo_panel_new_round")
                            </button>
                            <br/><br/>
                        }
                        <button
                            class="button"
                            name="send"
                            value="@(Model.IsPrivateMode ? $"/botmsg {Model.BotName},{Model.Trigger}loend {Model.RoomId}" : $"{Model.Trigger}loend")">
                            @GetString("lo_panel_stop")
                        </button>
                    </details>
                }
                else
                {
                    <br/>
                    <button
                        class="button"
                        name="send"
                        value="@(Model.IsPrivateMode ? $"/botmsg {Model.BotName},{Model.Trigger}lightsout {Model.RoomId}" : $"{Model.Trigger}lightsout")">
                        @GetString("lo_panel_play_again")
                    </button>
                }
            </td>
        </tr>
    </tbody>
</table>
