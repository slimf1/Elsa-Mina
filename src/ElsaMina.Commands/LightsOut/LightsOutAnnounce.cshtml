@using ElsaMina.Core.Services.Templates
@inherits ElsaMina.Core.Services.Templates.LocalizableTemplatePage<ElsaMina.Commands.LightsOut.LightsOutModel>

<div>
    <h3>@GetString("lo_panel_title")</h3>
    <span>@GetString("lo_panel_waiting_for_player")</span><br/><br/>
    <button
        class="button"
        name="send"
        value="/botmsg @Model.BotName,@(Model.Trigger)lojoin @Model.RoomId">
        @GetString("lo_panel_join")
    </button>
</div>
