@inherits ElsaMina.Core.Services.Templates.LocalizableTemplatePage<ElsaMina.Commands.Development.Commands.CommandListViewModel>

<div style="padding: 1rem;">
    @foreach (var group in Model.Commands.GroupBy(c => c.Category).OrderBy(g => g.Key))
    {
        <details style="margin-bottom: 0.75rem;">
            <summary style="font-size: 1.1rem; font-weight: bold; cursor: pointer; padding: 0.25rem 0;">
                @(string.IsNullOrEmpty(group.Key) ? "Other" : group.Key)
                <span style="font-weight: normal; font-size: 0.9rem; color: #666;">(@group.Count())</span>
            </summary>
            <div style="padding: 0.5rem 0 0 1rem;">
                @foreach (var command in group.OrderBy(c => c.Name))
                {
                    <div style="margin-bottom: 0.5rem;">
                        <span style="font-weight: bold;">@command.Name</span>
                        @if (command.Aliases.Any())
                        {
                            <span> &mdash; @GetString("allcommands_alias") : @string.Join(", ", command.Aliases)</span>
                        }
                        @if (command.IsAllowedInPrivateMessage)
                        {
                            <span> (@GetString("allcommands_allowed_in_pm"))</span>
                        }
                        @if (command.IsWhitelistOnly)
                        {
                            <span> (@GetString("allcommands_wl_only"))</span>
                        }
                        @if (command.IsPrivateMessageOnly)
                        {
                            <span> (@GetString("allcommands_pm_only"))</span>
                        }
                        <div style="font-size: 0.85rem; color: #444;">
                            @GetString("allcommands_required_rank") : @command.RequiredRank
                            @if (command.RoomRestriction.Any())
                            {
                                <span> &mdash; @GetString("allcommands_room_restriction", string.Join(", ", command.RoomRestriction))</span>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(command.HelpMessageKey))
                        {
                            <div style="font-size: 0.85rem; font-style: italic;">
                                @GetString(command.HelpMessageKey)
                            </div>
                        }
                    </div>
                }
            </div>
        </details>
    }
</div>
